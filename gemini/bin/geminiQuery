#!/bin/bash

# 1. Environment Setup (Crucial for Crontab)
export PATH="/usr/local/bin:/usr/bin:/bin:/home/john/work/jediller.github.io/gemini/bin"
export GEMINI_CLI_TRUST_WORKSPACE=true
export GEMINI_CLI_ALLOW_SHELL=true
# Load any other specific Gemini keys or paths if needed

# 2. Define Paths
BASE_DIR="/home/john/work/jediller.github.io/gemini"
QUERY_DIR="$BASE_DIR/query"
RESULT_DIR="$BASE_DIR/result"

# 3. Parameter Check
if [ -z "$1" ]; then
    echo "Usage: geminiQuery <filename.txt>"
    exit 1
fi

QUERY_FILE="$QUERY_DIR/$1"
RESULT_FILE="$RESULT_DIR/$1"

# 4. Existence Check
if [ ! -f "$QUERY_FILE" ]; then
    echo "Error: Query file '$1' not found in $QUERY_DIR"
    exit 1
fi

# 5. Execute Gemini Query
echo "Executing Gemini query for $1..."
INSTRUCTIONS=$(cat "$QUERY_FILE")

# Run the gemini command. 
# Using 'gemini' assuming it's in your PATH. 
if gemini "$INSTRUCTIONS" > "$RESULT_FILE"; then
    echo "Result saved to $RESULT_FILE"
else
    echo "Error: Gemini query failed."
    exit 1
fi

# 6. GitHub Bridge (The Push)
echo "Syncing to GitHub..."
cd "$BASE_DIR" || exit
git add "$RESULT_FILE"
git commit -m "Automated update: $1 $(date +'%Y-%m-%d %H:%M')"
git push origin master # or 'main' depending on your branch name

echo "Successfully pushed to GitHub."
