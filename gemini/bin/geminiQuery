#!/bin/bash

# Define base paths
BASE_DIR="/home/john/work/jediller.github.io/gemini"
QUERY_DIR="$BASE_DIR/query"
RESULT_DIR="$BASE_DIR/result"

# Check if a parameter was provided
if [ -z "$1" ]; then
    echo "Usage: geminiQuery <filename.txt>"
    exit 1
fi

QUERY_FILE="$QUERY_DIR/$1"
RESULT_FILE="$RESULT_DIR/$1"

# Check if the query file exists
if [ ! -f "$QUERY_FILE" ]; then
    echo "Error: Query file '$1' not found in $QUERY_DIR"
    exit 1
fi

echo "Processing query: $1..."

# Read the instructions from the file
INSTRUCTIONS=$(cat "$QUERY_FILE")

# Call the Gemini API and redirect output to the result directory
# Using the 'gemini' CLI tool (adjust if your command name differs)
if gemini "$INSTRUCTIONS" > "$RESULT_FILE"; then
    echo "Success! Result placed in $RESULT_FILE"
else
    echo "Error: Gemini query failed to execute."
    exit 1
fi
